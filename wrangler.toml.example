name = "idea-to-code-github-app"
main = "github-app-worker.js"
compatibility_date = "2026-06-18"

# Replace this with the deployed PWA origin.
# Examples:
# ALLOWED_ORIGINS = "https://dokysp.github.io,https://doky.space"
[vars]
ALLOWED_ORIGINS = "https://example.github.io"
GITHUB_APP_ID = "replace-with-github-app-id"

# Store a PKCS#8 private key with:
# wrangler secret put GITHUB_APP_PRIVATE_KEY
